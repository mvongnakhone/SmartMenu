# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Google Cloud Vision API key (required for /api/vision/detect)
GOOGLE_VISION_API_KEY=

# OpenAI API key (required for /api/parse, used for both gpt-3.5-turbo and gpt-4)
OPENAI_API_KEY=

# Google Cloud Translation API key (required for /api/translate)
GOOGLE_TRANSLATE_API_KEY=

# Optional: port for the local Flask dev server (defaults to 5001).
# Railway and other platforms set this automatically; leave blank in production.
PORT=5001
